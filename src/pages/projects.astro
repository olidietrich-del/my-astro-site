---
import BaseLayout from '../layout/BaseLayout.astro';
---
<BaseLayout>
  <section id="projects">
  <div class="container">
    <h2>My Projects</h2>
    <div class="projects">

      <!-- Card 1 -->
      <div class="projects__card">
        <p class="title">My Work</p>
        <img src="/images/photos_performance/IMG-20260214-WA0006.jpg" alt="Oli handstand on paperpile" class="img">
        <p>I create indoor and outdoor shows including physical theatre, circus, and live music. I perform in the streets of Dublin. If the temperature is above 15°C and the wind is no more than 15 km/h, come and say hello!</p>

        <!-- Weather widget inside the first card -->
        <section class="weather-section">
          <h3>Weather – Dublin</h3>
          <div class="weather-box">
            <p id="weather-info">Loading weather...</p>
          </div>
        </section>
      </div>

      <!-- Card 2 -->
      <div class="projects__card">
        <p class="title">Freestyle Orchestra</p>
        <img src="/images/photos_performance/IMG_1195.jpg" alt="Freestyle Orchestra performance" class="img">
        <p>Collaborative musical performances mixing circus and music. Bringing rhythm, energy, and spectacle to unique venues. Come and see us at Edinburgh Fringe 2026!</p>
      </div>

      <!-- Card 3 -->
      <div class="projects__card">
        <p class="title">Tocca Theater</p>
        <img src="/images/photos_performance/tocca_endlos_2025_leonie_pock_15.jpg" alt="Tocca Theater performance scientists" class="img">
        <p>Participated in inclusive theater projects combining physical theater, live music, and acrobatics. Creating unforgettable audience experiences.</p>
      </div>

    </div>
  </div>
</section>
</BaseLayout>